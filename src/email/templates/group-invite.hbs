<h2>{{title}}</h2>
<p><strong>{{inviterName}}</strong> {{body1}}</p>

<div style="background-color: #f0f0ff; border: 2px solid #6366F1; border-radius: 8px; padding: 20px; margin: 25px 0; text-align: center;">
  <div style="font-size: 14px; color: #666;">{{invitedGroupLabel}}</div>
  <div style="font-size: 24px; font-weight: bold; color: #6366F1; margin: 10px 0;">{{groupName}}</div>
</div>

<p>{{body2}}</p>

<div class="code-box">
  <div style="font-size: 14px; color: #666; margin-bottom: 10px;">{{codeLabel}}</div>
  <div class="code" style="letter-spacing: 4px;">{{inviteCode}}</div>
</div>

<div class="info">
  <strong>{{howToJoinLabel}}:</strong>
  <ol style="margin: 10px 0; padding-left: 20px;">
    <li style="margin: 10px 0;">{{step1}}</li>
    <li style="margin: 10px 0;">{{step2}}</li>
    <li style="margin: 10px 0;">{{step3}}</li>
  </ol>
</div>

<p style="text-align: center; color: #666; margin-top: 20px;">
  {{expiryText}}
</p>
